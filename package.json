{
  "name": "solar-maintenance-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:start": "electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.saran.solarmaintenance",
    "compression": "maximum",
    "productName": "Solar Maintenance Dashboard",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "dist/**/*",
      "main.cjs"
    ]
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "docx": "^9.6.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "file-saver": "^2.0.5",
    "idb-keyval": "^6.2.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1"
  }
}
